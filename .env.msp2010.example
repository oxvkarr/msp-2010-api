PORT=10000
DevServer=false
ChecksumEnabled=false
LogEveryRequest=false
CLUSTER_ENABLED=false

# Render API uses MSPRetro-style env names.
# If you are copying from the old MSP 2010 Render service:
# MONGODB_URI -> CUSTOMCONNSTR_URIMongoDB
# REMOTE_ASSET_BASE_URL -> MSP2010_CDN_URL
CUSTOMCONNSTR_URIMongoDB=mongodb+srv://USER:PASSWORD@HOST/msp_2010?appName=msp-2010
CUSTOMCONNSTR_SaltDB=change_this_database_password_salt
CUSTOMCONNSTR_SaltClient=change_this_client_checksum_salt

# Your MSP 2010 files are in the 2010/ prefix in R2.
MSP2010_CDN_URL=https://pub-your-r2-dev-url.r2.dev/2010
CORS_ORIGINS=https://pub-your-r2-dev-url.r2.dev,http://127.0.0.1:80,http://localhost:80
