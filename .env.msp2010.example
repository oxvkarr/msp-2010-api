PORT=1600
DevServer=true
ChecksumEnabled=false
LogEveryRequest=true

CUSTOMCONNSTR_URIMongoDB=mongodb+srv://USER:PASSWORD@HOST/msp_2010
CUSTOMCONNSTR_SaltDB=change_this_database_password_salt
CUSTOMCONNSTR_SaltClient=change_this_client_checksum_salt

# Put your R2 public development URL here, without a /2010 prefix.
# Example: https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev
MSP2010_CDN_URL=https://pub-your-r2-dev-url.r2.dev
CORS_ORIGINS=https://pub-your-r2-dev-url.r2.dev,http://127.0.0.1:80,http://localhost:80
